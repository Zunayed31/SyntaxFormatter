@page "/mssql"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>MSSQL Formatter — SyntaxFormatter</PageTitle>

<FormatterPanel FormatterName="MSSQL"
                Tag="tsql · uppercase"
                InputLabel="T-SQL"
                OutputLabel="Formatted"
                InputPlaceholder="Paste T-SQL here..."
                OutputPlaceholder="Formatted SQL will appear here..."
                FormatAsync="FormatAsync"/>

@code {
    private async Task<(string Result, string Error)> FormatAsync(string input)
    {
        try
        {
            var result = await JS.InvokeAsync<string>("syntaxFormatter.formatSql", input, "tsql");
            return (result, "");
        }
        catch (Exception ex)
        {
            return ("", $"Formatting error: {ex.Message}");
        }
    }
}
