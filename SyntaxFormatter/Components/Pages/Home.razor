@page "/"
@rendermode InteractiveServer

<PageTitle>Syntax Formatter</PageTitle>

<div class="landing-container">
    <div class="landing-hero">
        <h1 class="landing-title">Syntax Formatter</h1>
        <p class="landing-subtitle">A clean, fast formatter for developers. Paste your code and get it formatted instantly — no sign-up required.</p>
    </div>

    <div class="cards-grid">
        <a href="/json" class="formatter-card">
            <div class="card-icon"><i class="bi bi-braces"></i></div>
            <h3 class="card-title">JSON</h3>
            <p class="card-desc">Format, validate and minify JSON with detailed syntax error messages.</p>
            <span class="card-cta">Open →</span>
        </a>
        <a href="/javascript" class="formatter-card">
            <div class="card-icon"><i class="bi bi-code-slash"></i></div>
            <h3 class="card-title">JavaScript</h3>
            <p class="card-desc">Beautify JavaScript code with consistent indentation and spacing.</p>
            <span class="card-cta">Open →</span>
        </a>
        <a href="/oracle-sql" class="formatter-card">
            <div class="card-icon"><i class="bi bi-database"></i></div>
            <h3 class="card-title">Oracle SQL</h3>
            <p class="card-desc">Format Oracle PL/SQL queries with uppercase keywords and clean structure.</p>
            <span class="card-cta">Open →</span>
        </a>
        <a href="/mysql" class="formatter-card">
            <div class="card-icon"><i class="bi bi-table"></i></div>
            <h3 class="card-title">MySQL</h3>
            <p class="card-desc">Format MySQL queries, stored procedures and schema definitions.</p>
            <span class="card-cta">Open →</span>
        </a>
        <a href="/mssql" class="formatter-card">
            <div class="card-icon"><i class="bi bi-server"></i></div>
            <h3 class="card-title">MSSQL</h3>
            <p class="card-desc">Format Microsoft SQL Server T-SQL statements and stored procedures.</p>
            <span class="card-cta">Open →</span>
        </a>
        <a href="/yaml" class="formatter-card">
            <div class="card-icon"><i class="bi bi-file-earmark-code"></i></div>
            <h3 class="card-title">YAML</h3>
            <p class="card-desc">Parse and pretty-print YAML documents with consistent indentation.</p>
            <span class="card-cta">Open →</span>
        </a>
        <a href="/html" class="formatter-card">
            <div class="card-icon"><i class="bi bi-file-code"></i></div>
            <h3 class="card-title">HTML</h3>
            <p class="card-desc">Beautify and format HTML markup with proper nesting and indentation.</p>
            <span class="card-cta">Open →</span>
        </a>
    </div>
</div>
