<button class="theme-toggle-btn"
        id="theme-toggle-btn"
        onclick="toggleTheme()"
        aria-label="Switch to dark mode"
        aria-pressed="false"
        title="Switch to dark mode">
    <span class="theme-toggle-icon" aria-hidden="true"></span>
    <span class="theme-toggle-label">Dark mode</span>
</button>
